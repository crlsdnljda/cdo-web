# ===========================================================================
# CDO Solutions — Variables de entorno
# Copia este archivo a `.env` (local) y configura tus secretos REALES.
# En EasyPanel, configura estas mismas variables desde el panel del servicio.
# ===========================================================================

# --- MySQL ---------------------------------------------------------------
# Genera contraseñas fuertes para producción (mín. 24 chars).
# Comando rápido: openssl rand -base64 24
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=changeme_db_password

# --- Puertos host (solo para docker-compose.yml local) -------------------
# En producción/EasyPanel se ignoran (Traefik enruta vía dominio).
WP_PORT=8080
PMA_PORT=8081

# --- Dominio (referencia, no se inyecta automáticamente) -----------------
# WordPress autodetecta la URL desde el HTTP_HOST de la petición — no hace
# falta inyectarlo. Esta variable es solo informativa para tu deploy.
SITE_DOMAIN=cdo.solutions
